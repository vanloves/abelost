---
import { categories } from "@/data/categories";
import { calculators } from "@/data/calculators";
import { guides } from "@/data/guides";
import Logo from "@/components/Logo.astro";

const searchItems = [
  ...calculators.map((tool) => ({
    title: tool.name,
    detail: tool.summary,
    type: "Calculator",
    category: tool.category,
    href: `/calculators/${tool.slug}/`
  })),
  ...guides.map((guide) => ({
    title: guide.title,
    detail: guide.description,
    type: "Guide",
    category: guide.category,
    href: `/guides/${guide.slug}/`
  }))
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Abelost home">
      <Logo />
    </a>
    <nav class="desktop-nav" aria-label="Main navigation">
      <a href="/calculators/">All tools</a>
      <a href="/guides/">Guides</a>
      {categories.slice(0, 4).map((category) => (
        <a href={`/${category.id}/`}>{category.shortName}</a>
      ))}
    </nav>
    <div class="header-actions">
      <button class="icon-button search-button" type="button" data-search-open aria-label="Search Abelost">
        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path></svg>
      </button>
      <a class="browse" href="/calculators/">Browse 25 tools <span aria-hidden="true">↗</span></a>
      <button class="icon-button menu-button" type="button" data-menu-open aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
      </button>
    </div>
  </div>
</header>

<dialog class="search-dialog" data-search-dialog aria-labelledby="search-title">
  <div class="dialog-shell">
    <div class="dialog-head">
      <div>
        <p class="eyebrow">Find an answer</p>
        <h2 id="search-title">Search Abelost</h2>
      </div>
      <button class="close-button" type="button" data-search-close aria-label="Close search">×</button>
    </div>
    <label class="search-field">
      <span class="sr-only">Search calculators and guides</span>
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path></svg>
      <input type="search" placeholder="Try paint, energy, mileage, margin..." autocomplete="off" data-search-input />
    </label>
    <p class="search-status" data-search-status>Type to search 25 calculators and 10 guides.</p>
    <div class="search-results" data-search-results></div>
  </div>
</dialog>

<div class="mobile-panel" data-mobile-panel hidden>
  <div class="mobile-panel-head">
    <Logo />
    <button class="close-button" type="button" data-menu-close aria-label="Close menu">×</button>
  </div>
  <nav aria-label="Mobile navigation">
    <a href="/calculators/"><span>All calculators</span><b>25 tools</b></a>
    <a href="/guides/"><span>Practical guides</span><b>10 guides</b></a>
    {categories.map((category) => (
      <a href={`/${category.id}/`}><span>{category.name}</span><b>Explore</b></a>
    ))}
  </nav>
  <div class="mobile-links">
    <a href="/about/">About</a>
    <a href="/methodology/">Methodology</a>
    <a href="/contact/">Contact</a>
  </div>
</div>

<script is:inline define:vars={{ searchItems }}>
  const searchDialog = document.querySelector("[data-search-dialog]");
  const searchInput = document.querySelector("[data-search-input]");
  const searchResults = document.querySelector("[data-search-results]");
  const searchStatus = document.querySelector("[data-search-status]");
  const mobilePanel = document.querySelector("[data-mobile-panel]");
  const menuButton = document.querySelector("[data-menu-open]");

  const escapeHtml = (value) => value.replace(/[&<>"']/g, (character) => ({
    "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;"
  }[character]));

  const renderSearch = () => {
    if (!(searchInput instanceof HTMLInputElement) || !(searchResults instanceof HTMLElement) || !(searchStatus instanceof HTMLElement)) return;
    const query = searchInput.value.trim().toLowerCase();
    if (!query) {
      searchResults.innerHTML = "";
      searchStatus.textContent = "Type to search 25 calculators and 10 guides.";
      return;
    }
    const matches = searchItems.filter((item) =>
      `${item.title} ${item.detail} ${item.category} ${item.type}`.toLowerCase().includes(query)
    ).slice(0, 8);
    searchStatus.textContent = matches.length ? `${matches.length} matching result${matches.length === 1 ? "" : "s"}` : "No matches. Try a broader term.";
    searchResults.innerHTML = matches.map((item) => `
      <a href="${item.href}">
        <span><small>${escapeHtml(item.type)} · ${escapeHtml(item.category)}</small><strong>${escapeHtml(item.title)}</strong><em>${escapeHtml(item.detail)}</em></span>
        <b aria-hidden="true">↗</b>
      </a>
    `).join("");
  };

  document.querySelector("[data-search-open]")?.addEventListener("click", () => {
    if (searchDialog instanceof HTMLDialogElement) {
      searchDialog.showModal();
      window.setTimeout(() => searchInput instanceof HTMLInputElement && searchInput.focus());
    }
  });
  document.querySelector("[data-search-close]")?.addEventListener("click", () => {
    if (searchDialog instanceof HTMLDialogElement) searchDialog.close();
  });
  searchDialog?.addEventListener("click", (event) => {
    if (event.target === searchDialog && searchDialog instanceof HTMLDialogElement) searchDialog.close();
  });
  searchInput?.addEventListener("input", renderSearch);

  const closeMenu = () => {
    if (!(mobilePanel instanceof HTMLElement)) return;
    mobilePanel.hidden = true;
    document.body.classList.remove("menu-open");
    menuButton?.setAttribute("aria-expanded", "false");
  };
  menuButton?.addEventListener("click", () => {
    if (!(mobilePanel instanceof HTMLElement)) return;
    mobilePanel.hidden = false;
    document.body.classList.add("menu-open");
    menuButton.setAttribute("aria-expanded", "true");
  });
  document.querySelector("[data-menu-close]")?.addEventListener("click", closeMenu);
  mobilePanel?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));
</script>

<style>
  .site-header {
    background: rgba(247, 248, 243, 0.9);
    border-bottom: 1px solid rgba(220, 226, 216, 0.85);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px);
  }
  .header-inner { align-items: center; display: flex; height: 76px; justify-content: space-between; }
  .brand { align-items: center; display: flex; text-decoration: none; }
  .desktop-nav { display: flex; gap: 1.6rem; }
  .desktop-nav a { color: var(--muted); font-size: 0.93rem; font-weight: 600; text-decoration: none; }
  .desktop-nav a:hover { color: var(--ink); }
  .header-actions { align-items: center; display: flex; gap: 0.85rem; }
  .browse { font-size: 0.88rem; font-weight: 700; text-decoration: none; }
  .icon-button, .close-button { align-items: center; background: transparent; border: 0; color: var(--ink); cursor: pointer; display: inline-flex; justify-content: center; padding: 0; }
  .icon-button { height: 38px; width: 38px; }
  .icon-button svg, .search-field svg { fill: none; height: 20px; stroke: currentColor; stroke-linecap: round; stroke-width: 1.8; width: 20px; }
  .menu-button { display: none; }
  .close-button { border: 1px solid var(--line); border-radius: 50%; font-size: 1.5rem; height: 40px; width: 40px; }
  .search-dialog { background: transparent; border: 0; margin: 8vh auto; max-height: 84vh; max-width: 760px; padding: 0; width: calc(100% - 2rem); }
  .search-dialog::backdrop { background: rgba(12, 22, 18, 0.72); backdrop-filter: blur(5px); }
  .dialog-shell { background: var(--paper); border-radius: var(--radius); box-shadow: var(--shadow); padding: clamp(1.25rem, 4vw, 2rem); }
  .dialog-head { align-items: start; display: flex; justify-content: space-between; }
  .dialog-head .eyebrow { margin-bottom: 0.3rem; }
  .dialog-head h2 { font-size: 2rem; }
  .search-field { align-items: center; background: white; border: 1px solid var(--line); border-radius: 14px; display: flex; gap: 0.75rem; margin-top: 1.25rem; padding: 0 1rem; }
  .search-field:focus-within { border-color: var(--ink); box-shadow: 0 0 0 3px rgba(23, 35, 31, 0.08); }
  .search-field input { background: transparent; border: 0; color: var(--ink); font-size: 1rem; outline: 0; padding: 1rem 0; width: 100%; }
  .search-status { font-size: 0.78rem; margin: 0.8rem 0; }
  .search-results { display: grid; gap: 0.5rem; max-height: 52vh; overflow-y: auto; }
  .search-results :global(a) { align-items: center; background: white; border: 1px solid var(--line); border-radius: 12px; display: flex; gap: 1rem; justify-content: space-between; padding: 0.85rem 1rem; text-decoration: none; }
  .search-results :global(a:hover) { border-color: var(--ink); }
  .search-results :global(small), .search-results :global(strong), .search-results :global(em) { display: block; }
  .search-results :global(small) { color: var(--muted); font-size: 0.68rem; text-transform: capitalize; }
  .search-results :global(strong) { margin: 0.15rem 0; }
  .search-results :global(em) { color: var(--muted); font-size: 0.78rem; font-style: normal; line-height: 1.4; }
  .search-results :global(b) { color: var(--muted); }
  .mobile-panel { background: var(--paper); inset: 0; overflow-y: auto; padding: 1.2rem; position: fixed; z-index: 100; }
  .mobile-panel-head { align-items: center; display: flex; justify-content: space-between; }
  .mobile-panel nav { border-top: 1px solid var(--line); margin-top: 2rem; }
  .mobile-panel nav a { align-items: center; border-bottom: 1px solid var(--line); display: flex; font-family: Inter, system-ui, sans-serif; font-size: 1.35rem; font-weight: 750; justify-content: space-between; padding: 1.1rem 0; text-decoration: none; }
  .mobile-panel nav b { color: var(--muted); font-size: 0.72rem; font-weight: 600; }
  .mobile-links { display: flex; flex-wrap: wrap; gap: 1.2rem; margin-top: 2rem; }
  .mobile-links a { color: var(--muted); font-size: 0.85rem; }
  :global(body.menu-open) { overflow: hidden; }

  @media (max-width: 950px) {
    .desktop-nav { display: none; }
    .menu-button { display: inline-flex; }
    .browse { display: none; }
  }
</style>

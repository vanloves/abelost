---
interface Props {
  slug: string;
  size?: number;
  title?: string;
}

const { slug, size = 24, title } = Astro.props;
---

<svg
  class="tool-icon-svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="1.7"
  role={title ? "img" : undefined}
  aria-hidden={title ? undefined : "true"}
>
  {title && <title>{title}</title>}

  {slug === "paint" && (
    <>
      <path d="M4 5h10v5H4zM14 7h3a2 2 0 0 1 2 2v2" />
      <path d="M9 10v3h8v3" />
      <rect x="15" y="16" width="4" height="5" rx="1" />
    </>
  )}
  {slug === "flooring" && (
    <>
      <path d="M3 6h18M3 12h18M3 18h18M8 6v6m8 0v6M11 12v6" />
      <path d="m4 4 2-2m12 20 2-2" opacity=".55" />
    </>
  )}
  {slug === "tile" && (
    <>
      <rect x="3" y="3" width="8" height="8" rx="1" />
      <rect x="13" y="3" width="8" height="8" rx="1" />
      <rect x="3" y="13" width="8" height="8" rx="1" />
      <path d="M13 13h8v8h-8zM17 13v8M13 17h8" />
    </>
  )}
  {slug === "concrete" && (
    <>
      <path d="M4 8h13l2 10H6L4 8Z" />
      <path d="M8 8V5h5l2 3M8 12h7" />
      <path d="M9 18v2m7-2v2" />
    </>
  )}
  {slug === "drywall" && (
    <>
      <rect x="4" y="3" width="16" height="18" rx="1.5" />
      <path d="M12 3v18M4 9h8m0 6h8" />
      <circle cx="8" cy="6" r=".6" fill="currentColor" stroke="none" />
      <circle cx="16" cy="18" r=".6" fill="currentColor" stroke="none" />
    </>
  )}
  {slug === "mulch" && (
    <>
      <path d="M3 18c2-5 5-8 9-8s7 3 9 8H3Z" />
      <path d="M8 11c0-3 2-6 6-7 1 4-.5 7-4 8" />
      <path d="M6 15h.01M11 16h.01M16 14h.01" />
    </>
  )}
  {slug === "soil" && (
    <>
      <path d="M3 17h18M5 13h14M8 9h8" />
      <path d="M12 9V4m0 0-3 3m3-3 3 3" />
      <path d="M6 20h12" opacity=".55" />
    </>
  )}
  {slug === "gravel" && (
    <>
      <path d="M3 19h18L18 9H7L3 19Z" />
      <path d="m8 14 2-2 2 2 2-3 3 4" />
      <circle cx="7" cy="17" r=".7" />
      <circle cx="13" cy="17" r=".7" />
      <circle cx="17" cy="16.5" r=".7" />
    </>
  )}
  {slug === "sod" && (
    <>
      <path d="M4 8h12a4 4 0 0 1 0 8H7a3 3 0 0 1-3-3V8Z" />
      <circle cx="16" cy="12" r="2" />
      <path d="M7 8V5m3 3V4m3 4V5M4 19h16" />
    </>
  )}
  {slug === "lawn-seed" && (
    <>
      <path d="M12 20V9" />
      <path d="M12 12c-4 0-6-2-6-5 4 0 6 2 6 5Zm0 3c4 0 6-2 6-5-4 0-6 2-6 5Z" />
      <circle cx="5" cy="18" r="1" />
      <circle cx="19" cy="19" r="1" />
      <circle cx="7.5" cy="21" r=".7" />
    </>
  )}
  {slug === "electricity-cost" && (
    <>
      <path d="m13 2-7 11h6l-1 9 7-12h-6l1-8Z" />
      <path d="M3 20h4m10 0h4" opacity=".55" />
    </>
  )}
  {slug === "appliance-energy" && (
    <>
      <rect x="5" y="3" width="14" height="18" rx="2" />
      <circle cx="12" cy="13" r="4" />
      <path d="M8 7h2m4 0h2m-6 6c1 1 3 1 4 0" />
    </>
  )}
  {slug === "ac-running-cost" && (
    <>
      <rect x="3" y="4" width="18" height="8" rx="2" />
      <path d="M7 8h10M6 15c0 2 1 3 3 3m3-3v5m3-5c0 2 1 3 3 3" />
    </>
  )}
  {slug === "space-heater-cost" && (
    <>
      <rect x="5" y="3" width="14" height="18" rx="2" />
      <path d="M9 7c-2 2 2 3 0 5s2 3 0 5m6-10c-2 2 2 3 0 5s2 3 0 5" />
      <path d="M8 21v1m8-1v1" />
    </>
  )}
  {slug === "ev-charging" && (
    <>
      <path d="M4 15 6 9h10l2 6" />
      <path d="M3 15h16v4H3z" />
      <circle cx="7" cy="19" r="1.5" />
      <circle cx="15" cy="19" r="1.5" />
      <path d="M19 5h2v5h-2m1-5V2m-2 3V2" />
    </>
  )}
  {slug === "fuel-cost" && (
    <>
      <rect x="4" y="3" width="10" height="18" rx="2" />
      <path d="M7 6h4v4H7zM14 8h2l3 3v6a2 2 0 0 0 2 2" />
      <path d="m17 7 2 2" />
    </>
  )}
  {slug === "trip-cost" && (
    <>
      <circle cx="6" cy="18" r="2" />
      <circle cx="18" cy="6" r="2" />
      <path d="M7.5 16.5c1.5-1 1-3 3-4s3 0 4-2 0-3 2-4" />
      <path d="M4 6h5m-2-2 2 2-2 2" />
    </>
  )}
  {slug === "mpg" && (
    <>
      <path d="M4 16a8 8 0 1 1 16 0" />
      <path d="m12 16 4-6" />
      <circle cx="12" cy="16" r="1.5" />
      <path d="M6 19h12" />
    </>
  )}
  {slug === "cost-per-mile" && (
    <>
      <circle cx="8" cy="16" r="3" />
      <path d="M8 13V6h8l3 4v6h-8" />
      <path d="M14 6v5h5M4 5h3m-4 4h4" />
      <path d="M8 15v2m-1-1h2" />
    </>
  )}
  {slug === "ev-vs-gas" && (
    <>
      <path d="M12 4v16M9 7H5l-2 5 2 5h4" />
      <path d="M15 7h4l2 5-2 5h-4" />
      <path d="m6 10-1 3h3l-1 3m9-6h2v4h-2" />
    </>
  )}
  {slug === "profit-margin" && (
    <>
      <path d="M4 18 9 13l3 3 7-8" />
      <path d="M15 8h4v4" />
      <circle cx="7" cy="7" r="2" />
      <circle cx="17" cy="18" r="2" />
      <path d="m8 17 8-10" opacity=".55" />
    </>
  )}
  {slug === "markup" && (
    <>
      <path d="M4 5h9l7 7-8 8-8-8V5Z" />
      <circle cx="8" cy="9" r="1.2" />
      <path d="M11 15h5m-2.5-2.5v5" />
    </>
  )}
  {slug === "break-even" && (
    <>
      <path d="M4 19V5m0 14h16" />
      <path d="m6 16 5-5 3 2 5-6" />
      <path d="m6 8 4 4 3-2 6 6" opacity=".55" />
      <circle cx="12" cy="11" r="1.4" fill="currentColor" stroke="none" />
    </>
  )}
  {slug === "roas" && (
    <>
      <path d="M4 17V7m5 10v-5m5 5V9m5 8V4" />
      <path d="m4 7 5 5 5-3 5-5" />
      <path d="M4 21h16" opacity=".55" />
    </>
  )}
  {slug === "freelance-rate" && (
    <>
      <circle cx="12" cy="12" r="8" />
      <path d="M12 7v10m3-8.5c-.8-1-4-1.2-4 .8 0 2.5 5 1.2 5 4 0 2.1-3.5 2.1-5 1" />
      <path d="M4 4 2 6m18-2 2 2" opacity=".55" />
    </>
  )}
</svg>

<style>
  .tool-icon-svg {
    display: block;
    overflow: visible;
  }
</style>

---
import BaseLayout from "@/layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow = "Abelost" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="content-hero">
    <div class="container">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </header>
  <section class="section">
    <article class="container prose">
      <slot />
    </article>
  </section>
</BaseLayout>

<style>
  .content-hero { background: var(--ink); color: white; padding: 5.5rem 0; }
  .content-hero .eyebrow { color: var(--brand); }
  .content-hero h1 { font-size: clamp(2.8rem, 6vw, 4.8rem); }
  .content-hero p:last-child { color: #b3c0ba; font-size: 1.08rem; max-width: 720px; }
</style>
